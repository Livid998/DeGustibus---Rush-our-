; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="DeGustibus - Rush Hour"
run/main_scene="res://scenes/main/main.tscn"
config/icon="res://web/pwa_icon.svg"
config/features=PackedStringArray("4.7", "Mobile")

[autoload]

DataRegistry="*res://scripts/autoload/data_registry.gd"
GameState="*res://scripts/autoload/game_state.gd"
StorageManager="*res://scripts/autoload/storage_manager.gd"
CollectionManager="*res://scripts/autoload/collection_manager.gd"
SaveManager="*res://scripts/autoload/save_manager.gd"
EconomyManager="*res://scripts/autoload/economy_manager.gd"
SimulationManager="*res://scripts/autoload/simulation_manager.gd"
DayCycleManager="*res://scripts/autoload/day_cycle_manager.gd"
AudioManager="*res://scripts/autoload/audio_manager.gd"
PwaUpdateManager="*res://scripts/autoload/pwa_update_manager.gd"
WebPlatformProfile="*res://scripts/autoload/web_platform_profile.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/size/window_width_override=1280
window/size/window_height_override=720
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/handheld/orientation=1
window/dpi/allow_hidpi.web=false

